# ── Feed Crawler — Environment Variables ──

# Database
DATABASE_URL=postgresql://crawler:crawler_secret@db:5432/feed_crawler
POSTGRES_PASSWORD=crawler_secret

# Web
WEB_PORT=8000
JWT_SECRET=change-me-in-production

# Discord webhook (for notifications)
DISCORD_CRAWLER_WEBHOOK_URL=

# ISBNews (portal.isbnews.pl — HTTP Basic Auth)
SOURCE_ISBNEWS_USERNAME=
SOURCE_ISBNEWS_PASSWORD=

# SaaS integration webhook
SAAS_WEBHOOK_URL=
SAAS_WEBHOOK_API_KEY=
