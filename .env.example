# ── Feed Crawler — Environment Variables ──

# Database (default: SQLite)
DATABASE_URL=sqlite:///feed_crawler.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:pass@localhost:5432/feed_crawler

# Discord webhook (for notifications)
DISCORD_WEBHOOK_URL=

# ISBNews (portal.isbnews.pl — HTTP Basic Auth)
SOURCE_ISBNEWS_USERNAME=
SOURCE_ISBNEWS_PASSWORD=

# Newseria (info.newseria.pl — for on-demand media downloads only)
SOURCE_NEWSERIA_USERNAME=
SOURCE_NEWSERIA_PASSWORD=

# Webhook target (SaaS integration)
WEBHOOK_URL=
WEBHOOK_SECRET=
