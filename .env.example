# ── Feed Crawler — Environment Variables ──

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./feed_crawler.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/feed_crawler

# Logging
LOG_LEVEL=INFO

# SaaS Webhook (disabled by default — offline mode)
# SAAS_WEBHOOK_URL=https://press.impresjapr.pl/api/internal/ingest
# SAAS_WEBHOOK_API_KEY=your-internal-api-key

# Discord Notifications (errors, summaries, daily digest)
# DISCORD_CRAWLER_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# ── Authenticated Sources (closed/paywalled) ──
# Newseria (info.newseria.pl) — video, transcripts, audio
# SOURCE_NEWSERIA_USERNAME=
# SOURCE_NEWSERIA_PASSWORD=

# ISBNews (portal.isbnews.pl) — news agency dispatches
# SOURCE_ISBNEWS_USERNAME=
# SOURCE_ISBNEWS_PASSWORD=

# NASA API (optional, DEMO_KEY works for low volume)
# NASA_API_KEY=DEMO_KEY

# Fetch settings
FETCH_CONCURRENCY=20
DEFAULT_FETCH_INTERVAL_MINUTES=30
FETCH_TIMEOUT_SECONDS=30
USER_AGENT=FeedCrawler/1.0
